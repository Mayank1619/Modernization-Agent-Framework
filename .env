# Committed defaults: update AGENTIC_AI_API_KEY after pulling.

# Enable live AI generation
AGENTIC_AI_ENABLED=true

# Provider: openai (primary) or ollama
AGENTIC_AI_PROVIDER=openai

# Model name for selected provider
AGENTIC_AI_MODEL=gpt-4o-mini

# Base URL for selected provider
AGENTIC_AI_BASE_URL=https://api.openai.com

# Add your OpenAI key after cloning
AGENTIC_AI_API_KEY=

# Optional request timeout in seconds
AGENTIC_AI_TIMEOUT_SECONDS=120
