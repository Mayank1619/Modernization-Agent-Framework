# Safe committed template. Keep key values blank in git.

# Toggle AI mode. Set true only when keys below are configured.
AGENTIC_AI_ENABLED=true

# Primary model settings
AGENTIC_AI_PROVIDER=openai
AGENTIC_AI_MODEL=gpt-4o-mini
AGENTIC_AI_BASE_URL=https://api.openai.com
AGENTIC_AI_API_KEY=

# Secondary model settings for compare_with_claude mode
AGENTIC_CLAUDE_MODEL=claude-haiku-4-5-20251001
AGENTIC_CLAUDE_BASE_URL=https://api.anthropic.com
AGENTIC_CLAUDE_API_KEY=

# Optional timeout in seconds
AGENTIC_AI_TIMEOUT_SECONDS=120
