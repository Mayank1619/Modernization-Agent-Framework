# Copy to .env (or use as-is if .env is committed) and add your key.

# Enable live AI generation
AGENTIC_AI_ENABLED=true

# Provider: openai (primary) or ollama
AGENTIC_AI_PROVIDER=openai

# Model name for selected provider
AGENTIC_AI_MODEL=gpt-4o-mini

# Base URL for selected provider
AGENTIC_AI_BASE_URL=https://api.openai.com

# Add your OpenAI key
AGENTIC_AI_API_KEY=

# Optional request timeout in seconds
AGENTIC_AI_TIMEOUT_SECONDS=120

# Optional max completion tokens for primary provider responses
AGENTIC_AI_MAX_OUTPUT_TOKENS=

# Optional max completion tokens for Claude in dual-model mode
# If empty, falls back to AGENTIC_AI_MAX_OUTPUT_TOKENS when set.
AGENTIC_CLAUDE_MAX_OUTPUT_TOKENS=

# Optional Spec Kit integration settings
# Absolute path to your target project that owns the Spec Kit workflow.
SPEC_KIT_PROJECT_DIR=

# Relative folder inside target project where bundles should be imported.
SPEC_KIT_IMPORT_SUBDIR=spec-kit/imports
