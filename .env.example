# Copy this file to .env and update values as needed.

# Enable live AI generation
AGENTIC_AI_ENABLED=false

# Provider: ollama or openai
AGENTIC_AI_PROVIDER=ollama

# Model name for selected provider
AGENTIC_AI_MODEL=llama3.1

# Base URL for selected provider
AGENTIC_AI_BASE_URL=http://localhost:11434

# Required only for openai provider
AGENTIC_AI_API_KEY=

# Optional request timeout in seconds
AGENTIC_AI_TIMEOUT_SECONDS=120
